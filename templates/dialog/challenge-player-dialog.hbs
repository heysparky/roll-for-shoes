<div class="rfs-cpd">

  {{!-- Context plate: prompt + DC --}}
  <div class="rfs-cpd__context">
    {{#if prompt}}<div class="rfs-cpd__prompt">{{prompt}}</div>{{/if}}
    {{#if dcVisible}}
      <div class="rfs-popup__plate-dc">
        DC <span class="rfs-popup__plate-dc-num">{{dc}}</span>
      </div>
    {{/if}}
  </div>

  {{!-- Step: pick-skill --}}
  {{#if isPickSkill}}
    {{#if canInteract}}
      <div class="rfs-skill-list">
        <div class="rfs-skill-list__label">{{localize "RFS.Widget.ChooseSkill"}}</div>
        {{#each skills}}
          <div class="rfs-skill-list__row" data-skill-id="{{id}}">
            <div class="rfs-skill-list__row-name">{{name}}</div>
            <div class="rfs-skill-list__row-pips">
              {{#each pips}}<span class="rfs-skill-list__row-pip"></span>{{/each}}
            </div>
            <div class="rfs-skill-list__row-dice">{{level}}d6</div>
          </div>
        {{/each}}
      </div>
      <input type="hidden" name="skillId" value="">
      <button type="button"
              data-action="rfsDialogRoll"
              class="rfs-btn rfs-btn--primary rfs-btn--block"
              disabled>
        {{localize "RFS.Widget.RollButton"}}
      </button>
    {{else}}
      <p class="rfs-cpd__waiting">
        {{localize "RFS.Dialog.ChallengePlayer.WaitingRoll" name=actorName}}
      </p>
    {{/if}}
  {{/if}}

  {{!-- Step: rolling --}}
  {{#if isRolling}}
    <p class="rfs-cpd__rolling">Rolling…</p>
  {{/if}}

  {{!-- Roll result: shown from xp-spend / advancement / done steps --}}
  {{#if showResult}}
    <div class="rfs-cpd__result">
      <div class="rfs-cpd__dice-row">{{{diceHtml}}}</div>
      <div class="rfs-result__compare">
        {{#if rollResult.failed}}
          <span class="rfs-cpd__total rfs-result__total--failure">{{rollResult.total}}</span>
        {{else}}
          <span class="rfs-cpd__total rfs-result__total--success">{{rollResult.total}}</span>
        {{/if}}
        <span class="rfs-result__vs">vs</span>
        <span class="rfs-result__dc">{{dc}}</span>
      </div>
      {{#if rollResult.failed}}
        <div class="rfs-cpd__outcome rfs-cpd__outcome--fail">
          ✗ {{localize "RFS.Chat.Failure"}}
          <span class="rfs-result__xp-badge">
            <span class="rfs-result__xp-badge-num">+1</span>
            <span class="rfs-result__xp-badge-label">XP</span>
          </span>
        </div>
      {{else}}
        <div class="rfs-cpd__outcome rfs-cpd__outcome--success">
          ✓ {{localize "RFS.Chat.Success"}}
        </div>
      {{/if}}
    </div>
  {{/if}}

  {{!-- Step: xp-spend --}}
  {{#if isXpSpend}}
    <div class="rfs-cpd__xpspend">
      {{#if canInteract}}
        {{#if canAffordXp}}
          <div class="rfs-xp-option__hint">
            {{localize "RFS.Dialog.Advancement.SpendHint" skill=skillName level=nextSkillLevel}}
          </div>
          <button type="button"
                  data-action="rfsDialogSpendXp"
                  class="rfs-btn rfs-btn--ghost rfs-btn--block">
            {{localize "RFS.Chat.SpendXp" cost=xpCost}}
          </button>
        {{else}}
          <p class="rfs-cpd__cant-afford">
            {{localize "RFS.Warn.NotEnoughXp" cost=xpCost xp=currentXp}}
          </p>
        {{/if}}
      {{/if}}
      <button type="button"
              data-action="rfsDialogDismiss"
              class="rfs-btn rfs-btn--secondary rfs-btn--block">
        {{localize "RFS.Dialog.ChallengePlayer.Close"}}
      </button>
    </div>
  {{/if}}

  {{!-- Step: advancement --}}
  {{#if isAdvancement}}
    <div class="rfs-cpd__advancement">
      <h3 class="rfs-advance__heading">{{localize "RFS.Chat.AllSixesHeading"}}</h3>
      <p class="rfs-cpd__advancement-prompt">{{newSkillPrompt}}</p>
      {{#if canInteract}}
        <input type="text"
               name="newSkillName"
               class="rfs-cpd__skill-name-input"
               placeholder="{{localize "RFS.Dialog.NewSkill.Placeholder"}}"
               maxlength="60">
        <button type="button"
                data-action="rfsDialogClaim"
                class="rfs-btn rfs-btn--gold rfs-btn--block"
                disabled>
          ✦ {{localize "RFS.Dialog.Advancement.Confirm"}}
        </button>
      {{else}}
        <p class="rfs-cpd__waiting">
          {{localize "RFS.Dialog.ChallengePlayer.WaitingAdvancement" name=actorName}}
        </p>
      {{/if}}
    </div>
  {{/if}}

  {{!-- Step: done --}}
  {{#if isDone}}
    <div class="rfs-popup__foot">
      <p class="rfs-popup__done">{{doneNote}}</p>
    </div>
  {{/if}}

</div>
