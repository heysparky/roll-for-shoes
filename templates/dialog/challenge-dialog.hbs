{{!-- templates/dialog/challenge-dialog.hbs --}}
{{!-- GM roll initiation: DC input (type or roll Nd6) + token list. --}}

<section class="rfs-challenge-dialog">

  {{!-- ── DC ────────────────────────────────────────────────────────────────── --}}
  <div class="rfs-challenge-dialog__section">
    <label class="rfs-challenge-dialog__label">DC</label>
    <div class="rfs-challenge-dialog__dc-row">
      <input type="number"
             name="dc"
             value="{{dc}}"
             min="1"
             max="99"
             class="rfs-challenge-dialog__dc-input"
             autofocus>
      <span class="rfs-challenge-dialog__dc-sep">or roll</span>
      <input type="number"
             name="dcDice"
             value="{{dcDice}}"
             min="1"
             max="10"
             class="rfs-challenge-dialog__dc-dice">
      <span class="rfs-challenge-dialog__dc-label">d6</span>
      <button type="button"
              data-action="rollDc"
              class="rfs-btn rfs-btn--roll rfs-challenge-dialog__dc-roll-btn">
        Roll
      </button>
    </div>

    {{#if dcRollHtml}}
      <div class="rfs-challenge-dialog__dc-result">{{{dcRollHtml}}}</div>
    {{/if}}
  </div>

  {{!-- ── Called Tokens ───────────────────────────────────────────────────── --}}
  <div class="rfs-challenge-dialog__section">
    <label class="rfs-challenge-dialog__label">
      {{localize "RFS.Dialog.Challenge.CalledTokens"}}
    </label>

    {{#if tokens.length}}
      <ul class="rfs-challenge-dialog__token-list">
        {{#each tokens}}
          <li class="rfs-challenge-dialog__token">
            <span class="rfs-challenge-dialog__token-name">{{this.name}}</span>
            <button type="button"
                    class="rfs-btn rfs-btn--icon rfs-btn--danger"
                    data-action="removeToken"
                    data-token-id="{{this.id}}"
                    title="Remove">
              &#x2715;
            </button>
          </li>
        {{/each}}
      </ul>
    {{else}}
      <p class="rfs-challenge-dialog__empty">
        {{localize "RFS.Dialog.Challenge.NoTokens"}}
      </p>
    {{/if}}
  </div>

  {{!-- ── Footer ────────────────────────────────────────────────────────────── --}}
  <div class="rfs-challenge-dialog__footer">
    <button type="submit" class="rfs-btn rfs-btn--primary">
      {{localize "RFS.Dialog.Challenge.Confirm"}}
    </button>
    <button type="button"
            class="rfs-btn"
            onclick="this.closest('.application').dispatchEvent(new Event('close'))">
      {{localize "RFS.Dialog.Challenge.Cancel"}}
    </button>
  </div>

</section>
