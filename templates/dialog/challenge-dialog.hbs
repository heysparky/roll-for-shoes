{{!-- templates/dialog/challenge-dialog.hbs --}}
{{!-- GM roll initiation: DC stepper + canonical quick-jumps + dice picker + token list. --}}

<section class="rfs-challenge-dialog">

  {{!-- ── DC Stepper ────────────────────────────────────────────────────────── --}}
  <div class="rfs-challenge-dialog__section">
    <label class="rfs-challenge-dialog__label">DC</label>

    <div class="rfs-challenge-dialog__dc-stepper">
      <button type="button"
              class="rfs-btn rfs-challenge-dialog__step-btn"
              data-action="stepDc"
              data-dir="-1">&#x2212;</button>
      <span class="rfs-challenge-dialog__dc-value">{{dc}}</span>
      <button type="button"
              class="rfs-btn rfs-challenge-dialog__step-btn"
              data-action="stepDc"
              data-dir="1">&#x2b;</button>
    </div>

    <div class="rfs-challenge-dialog__dc-canonicals">
      {{#each canonicals}}
        <button type="button"
                class="rfs-btn rfs-challenge-dialog__dc-canonical{{#if this.active}} rfs-challenge-dialog__dc-canonical--active{{/if}}"
                data-action="setDc"
                data-value="{{this.value}}">
          {{this.value}}
        </button>
      {{/each}}
    </div>
  </div>

  {{!-- ── Dice Picker ─────────────────────────────────────────────────────── --}}
  <div class="rfs-challenge-dialog__section">
    <label class="rfs-challenge-dialog__label">
      {{localize "RFS.Dialog.Challenge.DcDiceLabel"}}
    </label>
    <div class="rfs-challenge-dialog__dice-picker">
      {{#each diceOptions}}
        <button type="button"
                class="rfs-btn rfs-challenge-dialog__dice-opt{{#if this.selected}} rfs-challenge-dialog__dice-opt--active{{/if}}"
                data-action="selectDice"
                data-dice="{{this.n}}">
          {{this.label}}
        </button>
      {{/each}}
    </div>
    {{#if isRolled}}
      <div class="rfs-challenge-dialog__dice-hint">
        {{localize "RFS.Dialog.Challenge.DiceHintRoll"}}
      </div>
    {{/if}}
  </div>

  {{!-- ── Called Tokens ───────────────────────────────────────────────────── --}}
  <div class="rfs-challenge-dialog__section">
    <label class="rfs-challenge-dialog__label">
      {{localize "RFS.Dialog.Challenge.CalledTokens"}}
    </label>

    {{#if tokens.length}}
      <ul class="rfs-challenge-dialog__token-list">
        {{#each tokens}}
          <li class="rfs-challenge-dialog__token">
            <span class="rfs-challenge-dialog__token-name">{{this.name}}</span>
            <button type="button"
                    class="rfs-btn rfs-btn--icon rfs-btn--danger"
                    data-action="removeToken"
                    data-token-id="{{this.id}}"
                    title="Remove">
              &#x2715;
            </button>
          </li>
        {{/each}}
      </ul>
    {{else}}
      <p class="rfs-challenge-dialog__empty">
        {{localize "RFS.Dialog.Challenge.NoTokens"}}
      </p>
    {{/if}}
  </div>

  {{!-- ── Footer ────────────────────────────────────────────────────────────── --}}
  <div class="rfs-challenge-dialog__footer">
    <button type="button"
            class="rfs-btn"
            onclick="this.closest('.application').dispatchEvent(new Event('close'))">
      {{localize "RFS.Dialog.Challenge.Cancel"}}
    </button>
    <button type="submit" class="rfs-btn rfs-btn--primary">
      {{localize "RFS.Dialog.Challenge.Confirm"}}
    </button>
  </div>

</section>
