{{!-- templates/actor/character-sheet.hbs --}}
<div class="rfs-sheet character">

  {{!-- ── Header: portrait | identity | xp ─────────────────────────────── --}}
  <header class="rfs-sheet__header">

    <button type="button"
            class="rfs-sheet__portrait-btn"
            data-action="editPortrait"
            title="Click to change portrait">
      <img class="rfs-sheet__portrait"
           src="{{actor.img}}"
           alt="{{actor.name}}">
    </button>

    <div class="rfs-sheet__identity">
      <input class="rfs-sheet__name"
             type="text"
             name="name"
             value="{{actor.name}}"
             placeholder="{{localize 'RFS.Placeholder.ActorName'}}"
             {{#unless isEditable}}disabled{{/unless}}>
    </div>

    <div class="rfs-sheet__xp">
      <label class="rfs-sheet__xp-label" for="rfs-xp-input">{{localize 'RFS.Label.XP'}}</label>
      <input class="rfs-sheet__xp-value"
             id="rfs-xp-input"
             type="number"
             name="system.xp"
             value="{{xp}}"
             min="0"
             {{#unless isEditable}}disabled{{/unless}}>
    </div>

  </header>

  {{!-- ── Main body ───────────────────────────────────────────────────── --}}
  <section class="rfs-sheet__body">

    <div class="rfs-panel rfs-panel--skills">
      <div class="rfs-panel__header">
        <h2 class="rfs-panel__title">{{localize 'RFS.Label.Skills'}}</h2>
        <button type="button"
                class="rfs-section__action"
                data-action="openSkillMap"
                title="{{localize 'RFS.Action.OpenSkillMap'}}">
          ⤢
        </button>
      </div>

      {{> "systems/roll-for-shoes/templates/actor/partials/skill-index.hbs"
          skills=skills
          isEditable=isEditable }}
    </div>

    <div class="rfs-panel rfs-panel--statuses">
      <div class="rfs-panel__header">
        <h2 class="rfs-panel__title">{{localize 'RFS.Label.Statuses'}}</h2>
        {{#if isEditable}}
          <button type="button"
                  class="rfs-section__action"
                  data-action="addStatus"
                  title="{{localize 'RFS.Action.AddStatus'}}">
            + {{localize 'RFS.Action.AddStatus'}}
          </button>
        {{/if}}
      </div>

      {{> "systems/roll-for-shoes/templates/actor/partials/status-list.hbs"
          statuses=statuses
          isEditable=isEditable }}
    </div>

    <div class="rfs-panel rfs-panel--biography">
      <div class="rfs-panel__header">
        <h2 class="rfs-panel__title">{{localize 'RFS.Label.Biography'}}</h2>
      </div>
      <textarea class="rfs-sheet__biography"
                name="system.biography"
                placeholder="Character background, appearance, notes…"
                {{#unless isEditable}}disabled{{/unless}}>{{actor.system.biography}}</textarea>
    </div>

  </section>

</div>
