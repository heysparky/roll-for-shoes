{{!-- templates/actor/character-sheet.hbs --}}
<div class="rfs-sheet character">

  {{!-- ── Header: portrait | (name + xp) / background ─────────────────── --}}
  <header class="rfs-sheet__header">

    <img class="rfs-sheet__portrait{{#if editMode}} rfs-sheet__portrait--editable{{/if}}"
         src="{{actor.img}}"
         alt="{{actor.name}}"
         {{#if editMode}}data-action="editImage" data-edit="img" title="Click to change portrait"{{/if}}>

    <div class="rfs-sheet__header-right">
      <div class="rfs-sheet__header-top">
        {{#if editMode}}
          <input class="rfs-sheet__name"
                 type="text"
                 name="name"
                 value="{{actor.name}}"
                 placeholder="{{localize 'RFS.Placeholder.ActorName'}}">
        {{else}}
          <span class="rfs-sheet__name rfs-sheet__name--display">{{actor.name}}</span>
        {{/if}}
        <div class="rfs-sheet__xp">
          <span class="rfs-sheet__xp-label">{{localize 'RFS.Label.XP'}}</span>
          {{#if editMode}}
            <input class="rfs-sheet__xp-value"
                   type="number"
                   name="system.xp"
                   value="{{xp}}"
                   min="0">
          {{else}}
            <span class="rfs-sheet__xp-value">{{xp}}</span>
          {{/if}}
        </div>
        {{#if editMode}}
          <button type="button"
                  class="rfs-btn rfs-btn--gold rfs-btn--small"
                  data-action="toggleEditMode">
            &#x2714; {{localize 'RFS.Action.DoneEditing'}}
          </button>
        {{/if}}
      </div>
      {{#if editMode}}
        <textarea class="rfs-sheet__biography"
                  name="system.biography"
                  placeholder="{{localize 'RFS.Placeholder.Biography'}}">{{actor.system.biography}}</textarea>
      {{else}}
        <div class="rfs-sheet__biography--display"
             data-placeholder="{{localize 'RFS.Placeholder.Biography'}}">{{actor.system.biography}}</div>
      {{/if}}
    </div>

  </header>

  {{!-- ── Tab nav ───────────────────────────────────────────────────────── --}}
  <nav class="rfs-tabs">
    <button type="button"
            class="rfs-tabs__btn rfs-tabs__btn--active"
            data-action="switchTab"
            data-tab="skills">
      {{localize 'RFS.Label.Skills'}}
    </button>
    <button type="button"
            class="rfs-tabs__btn"
            data-action="switchTab"
            data-tab="inventory">
      {{localize 'RFS.Label.Inventory'}}
    </button>
    <button type="button"
            class="rfs-tabs__btn"
            data-action="switchTab"
            data-tab="statuses">
      {{localize 'RFS.Label.Statuses'}}
    </button>
    <button type="button"
            class="rfs-tabs__btn"
            data-action="switchTab"
            data-tab="history">
      {{localize 'RFS.Label.RollHistory'}}
    </button>
  </nav>

  {{!-- ── Tab panels ─────────────────────────────────────────────────────── --}}
  <div class="rfs-tab-panels">

    {{!-- Skills tab — ONLY skills here. Statuses moved to its own tab below. --}}
    <div class="rfs-tab-panel rfs-tab-panel--active" data-tab="skills">

      <div class="rfs-panel rfs-panel--skills">
        {{> "systems/roll-for-shoes/templates/actor/partials/skill-index.hbs"
            skills=skills
            editMode=editMode }}
      </div>

    </div>

    {{!-- Statuses tab (was nested inside Skills) --}}
    <div class="rfs-tab-panel" data-tab="statuses">

      <div class="rfs-panel rfs-panel--statuses">
        <div class="rfs-panel__header">
          <h2 class="rfs-panel__title">{{localize 'RFS.Label.Statuses'}}</h2>
          {{#if isEditable}}
            <button type="button"
                    class="rfs-section__action"
                    data-action="addStatus"
                    title="{{localize 'RFS.Action.AddStatus'}}">
              + {{localize 'RFS.Action.AddStatus'}}
            </button>
          {{/if}}
        </div>

        {{> "systems/roll-for-shoes/templates/actor/partials/status-list.hbs"
            statuses=statuses
            isEditable=isEditable }}
      </div>

    </div>

    {{!-- Inventory tab --}}
    <div class="rfs-tab-panel" data-tab="inventory">

      <div class="rfs-panel rfs-panel--inventory">
        <div class="rfs-panel__header">
          <h2 class="rfs-panel__title">{{localize 'RFS.Label.Inventory'}}</h2>
          {{#if isEditable}}
            <button type="button"
                    class="rfs-section__action"
                    data-action="addItem"
                    title="{{localize 'RFS.Action.AddItem'}}">
              + {{localize 'RFS.Action.AddItem'}}
            </button>
          {{/if}}
        </div>

        {{> "systems/roll-for-shoes/templates/actor/partials/inventory-list.hbs"
            inventory=inventory
            isEditable=isEditable }}
      </div>

    </div>

    {{!-- Roll history tab --}}
    <div class="rfs-tab-panel" data-tab="history">

      <div class="rfs-history">
        {{#each rollHistory}}
          <div class="rfs-history-entry
                       {{#if allSixes}}rfs-history-entry--allsixes
                       {{else if failed}}rfs-history-entry--failure
                       {{else}}rfs-history-entry--success{{/if}}">
            <span class="rfs-history-entry__time">{{timeDisplay}}</span>
            <span class="rfs-history-entry__skill">{{skillName}} {{skillLevel}}d6</span>
            <span class="rfs-history-entry__dice">[{{diceDisplay}}]</span>
            <span class="rfs-history-entry__total">{{total}} vs {{difficulty}}</span>
            <span class="rfs-history-entry__outcome">
              {{#if allSixes}}&#x2726;{{else if failed}}&#x2718;{{else}}&#x2714;{{/if}}
            </span>
          </div>
        {{else}}
          <div class="rfs-empty">{{localize 'RFS.Label.NoHistory'}}</div>
        {{/each}}
      </div>

    </div>

  </div>

</div>
