{{!-- templates/actor/partials/status-list.hbs --}}
{{!--
  Status list. Each status has a name and a numeric modifier.
  Positive values are advantages, negative are penalties.

  Class name contract (must match vellum.css):
    .rfs-status--pos   — positive modifier
    .rfs-status--neg   — negative modifier
    .rfs-status__mod   — the number display
    .rfs-status__name  — the label
--}}

<div class="rfs-statuses">
  {{#if statuses.length}}
    {{#each statuses}}
      <div class="rfs-status {{#if (gt value 0)}}rfs-status--pos{{else if (lt value 0)}}rfs-status--neg{{/if}}"
           data-status-id="{{id}}">

        <span class="rfs-status__mod">{{rfsSignedNumber value}}</span>

        {{#if ../isEditable}}
          <input class="rfs-status__name"
                 type="text"
                 name="system.statuses.{{@index}}.name"
                 value="{{name}}">
          <input class="rfs-status__value"
                 type="number"
                 name="system.statuses.{{@index}}.value"
                 value="{{value}}"
                 style="width: 3.5rem">
          <button type="button"
                  class="rfs-btn rfs-btn--icon"
                  data-action="deleteStatus"
                  data-status-id="{{id}}"
                  title="{{localize 'RFS.Action.DeleteStatus'}}">
            ✕
          </button>
        {{else}}
          <span class="rfs-status__name">{{name}}</span>
        {{/if}}

      </div>
    {{/each}}
  {{else}}
    <p class="rfs-empty">{{localize 'RFS.Label.NoStatuses'}}</p>
  {{/if}}
</div>
