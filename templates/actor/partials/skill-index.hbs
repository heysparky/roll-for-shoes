{{!-- templates/actor/partials/skill-index.hbs --}}
<div class="rfs-skill-index">
  {{#each skills}}
    <div class="rfs-skill-index__row" style="--rfs-skill-depth: {{depth}};">
      <div class="rfs-skill-index__pips">
        {{#rfsRepeat level}}<span class="rfs-pip"></span>{{/rfsRepeat}}
      </div>

      <button type="button"
              class="rfs-skill-index__name{{#if (rfsIsRoot this)}} rfs-skill-index__name--root{{/if}}"
              data-action="rollSkill"
              data-skill-id="{{id}}"
              title="Roll {{name}} ({{level}}d6)">
        {{name}}
      </button>

      {{#if ../isEditable}}
        {{#unless (rfsIsRoot this)}}
          <button type="button"
                  class="rfs-btn rfs-btn--icon rfs-skill-index__rename-btn"
                  data-action="renameSkill"
                  data-skill-id="{{id}}"
                  title="Rename">&#x270e;</button>
          <button type="button"
                  class="rfs-btn rfs-btn--icon rfs-skill-index__delete-btn"
                  data-action="deleteSkill"
                  data-skill-id="{{id}}"
                  title="Delete {{name}}">&#x2715;</button>
        {{/unless}}
      {{/if}}
    </div>
  {{/each}}
</div>
