{{!-- templates/actor/partials/skill-node.hbs --}}
{{!--
  Renders one skill node in the horizontal bracket tree.

  Layout: flex row — card on left, children column on right.
  Children are found by filtering allSkills for parentId === skill.id,
  using the same {{#each allSkills}}{{#if eq parentId}}...{{/if}}{{/each}}
  pattern as the original partial.

  rfs-skill-node--branch is added via a separate pass below — we can't
  know if there are children until we've iterated, so we use a CSS trick:
  .rfs-skill-node__children:not(:empty) triggers the connector line, and
  --branch is applied unconditionally then hidden when children is empty.
--}}

<div class="rfs-skill-node rfs-skill-node--branch" data-skill-id="{{skill.id}}">

  <button type="button"
          class="rfs-skill-node__card{{#if (rfsIsRoot skill)}} rfs-skill-node__card--root{{/if}}"
          data-action="rollSkill"
          data-skill-id="{{skill.id}}"
          title="Roll {{skill.name}} ({{skill.level}}d6)">
    <div class="rfs-skill-node__row">
      <div class="rfs-skill-node__name">{{skill.name}}</div>
      <div class="rfs-skill-node__pips">
        {{#rfsRepeat skill.level}}
          <span class="rfs-pip"></span>
        {{/rfsRepeat}}
      </div>
    </div>
    <span class="rfs-skill-node__hint">Roll {{skill.level}}d6</span>
  </button>

  {{!-- Children column — only rendered if this node has children --}}
  <div class="rfs-skill-node__children">
    {{#each allSkills}}
      {{#if (eq this.parentId ../skill.id)}}
        {{> "systems/roll-for-shoes/templates/actor/partials/skill-node.hbs"
            skill=this
            allSkills=../allSkills
            isEditable=../isEditable }}
      {{/if}}
    {{/each}}
  </div>

</div>
