{{!-- templates/actor/partials/skill-tree.hbs --}}
{{!--
  Entry point for the skill tree. Finds the root node (parentId = "")
  and passes it to skill-node.hbs, which recurses for each generation.

  The rfs-skill-tree__canvas wrapper lives in character-sheet.hbs so the
  sheet controls scroll/overflow at the right level.
--}}

{{#each skills}}
  {{#unless this.parentId}}
    {{> "systems/roll-for-shoes/templates/actor/partials/skill-node.hbs"
        skill=this
        allSkills=../skills
        isEditable=../isEditable }}
  {{/unless}}
{{/each}}
